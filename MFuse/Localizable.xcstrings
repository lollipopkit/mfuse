    "extensionGuide.message" : {
      "extractionState" : "stale",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "MFuse needs a system extension to mount remote files.\nPlease enable it in System Settings."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "MFuse necesita una extensión del sistema para montar archivos remotos.\nActívala en Ajustes del Sistema."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "MFuse a besoin d’une extension système pour monter des fichiers distants.\nActivez-la dans Réglages Système."
          }
        },
        "id" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "MFuse memerlukan ekstensi sistem untuk memasang file remote.\nAktifkan di Pengaturan Sistem."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "MFuse richiede un’estensione di sistema per montare file remoti.\nAbilitala in Impostazioni di Sistema."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "MFuse でリモートファイルをマウントするにはシステム拡張機能が必要です。\nシステム設定で有効にしてください。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "MFuse가 원격 파일을 마운트하려면 시스템 확장이 필요합니다.\n시스템 설정에서 활성화하세요."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "MFuse 需要一个系统扩展来挂载远程文件。\n请在系统设置中启用它。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "MFuse 需要系統擴充功能來掛載遠端檔案。\n請在系統設定中啟用它。"
          }
        }
      }
    },
