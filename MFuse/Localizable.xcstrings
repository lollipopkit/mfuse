    "settings.icloud.enabled" : { "localizations" : { "en" : { "stringUnit" : { "state" : "translated", "value" : "Syncs connection configs and credentials across devices with iCloud." } }, "zh-Hans" : { "stringUnit" : { "state" : "translated", "value" : "使用 iCloud 在设备间同步连接配置和凭证。" } }, "zh-Hant" : { "stringUnit" : { "state" : "translated", "value" : "使用 iCloud 在裝置間同步連線設定與憑證。" } }, "es" : { "stringUnit" : { "state" : "translated", "value" : "Sincroniza configuraciones y credenciales entre dispositivos con iCloud." } }, "ja" : { "stringUnit" : { "state" : "translated", "value" : "iCloud を使って接続設定と認証情報をデバイス間で同期します。" } }, "ko" : { "stringUnit" : { "state" : "translated", "value" : "iCloud로 기기 간 연결 구성과 자격 증명을 동기화합니다." } }, "it" : { "stringUnit" : { "state" : "translated", "value" : "Sincronizza configurazioni e credenziali tra dispositivi con iCloud." } }, "id" : { "stringUnit" : { "state" : "translated", "value" : "Menyinkronkan konfigurasi koneksi dan kredensial antar perangkat dengan iCloud." } }, "fr" : { "stringUnit" : { "state" : "translated", "value" : "Synchronise les configurations de connexion et les identifiants entre appareils avec iCloud." } } } },
