    "settings.launchAtLogin.enabled" : { "localizations" : { "en" : { "stringUnit" : { "state" : "translated", "value" : "MFuse will launch automatically after you sign in." } }, "zh-Hans" : { "stringUnit" : { "state" : "translated", "value" : "登录后 MFuse 会自动启动。" } }, "zh-Hant" : { "stringUnit" : { "state" : "translated", "value" : "登入後 MFuse 會自動啟動。" } }, "es" : { "stringUnit" : { "state" : "translated", "value" : "MFuse se iniciará automáticamente después de iniciar sesión." } }, "ja" : { "stringUnit" : { "state" : "translated", "value" : "サインイン後に MFuse が自動的に起動します。" } }, "ko" : { "stringUnit" : { "state" : "translated", "value" : "로그인 후 MFuse가 자동으로 실행됩니다." } }, "it" : { "stringUnit" : { "state" : "translated", "value" : "MFuse si avvierà automaticamente dopo l’accesso." } }, "id" : { "stringUnit" : { "state" : "translated", "value" : "MFuse akan berjalan otomatis setelah Anda masuk." } }, "fr" : { "stringUnit" : { "state" : "translated", "value" : "MFuse se lancera automatiquement après votre connexion." } } } },
    "settings.launchAtLogin.notRegistered" : { "localizations" : { "en" : { "stringUnit" : { "state" : "translated", "value" : "Launch at login is off." } }, "zh-Hans" : { "stringUnit" : { "state" : "translated", "value" : "登录时启动已关闭。" } }, "zh-Hant" : { "stringUnit" : { "state" : "translated", "value" : "登入時啟動已關閉。" } }, "es" : { "stringUnit" : { "state" : "translated", "value" : "Iniciar al iniciar sesión está desactivado." } }, "ja" : { "stringUnit" : { "state" : "translated", "value" : "ログイン時に起動はオフです。" } }, "ko" : { "stringUnit" : { "state" : "translated", "value" : "로그인 시 실행이 꺼져 있습니다." } }, "it" : { "stringUnit" : { "state" : "translated", "value" : "Avvio all’accesso disattivato." } }, "id" : { "stringUnit" : { "state" : "translated", "value" : "Jalankan saat login nonaktif." } }, "fr" : { "stringUnit" : { "state" : "translated", "value" : "Le lancement à l’ouverture de session est désactivé." } } } },
    "settings.launchAtLogin.requiresApproval" : { "localizations" : { "en" : { "stringUnit" : { "state" : "translated", "value" : "Launch at login needs approval in System Settings." } }, "zh-Hans" : { "stringUnit" : { "state" : "translated", "value" : "登录时启动需要在系统设置中批准。" } }, "zh-Hant" : { "stringUnit" : { "state" : "translated", "value" : "登入時啟動需要在系統設定中核准。" } }, "es" : { "stringUnit" : { "state" : "translated", "value" : "Iniciar al iniciar sesión necesita aprobación en Ajustes del Sistema." } }, "ja" : { "stringUnit" : { "state" : "translated", "value" : "ログイン時に起動するにはシステム設定での承認が必要です。" } }, "ko" : { "stringUnit" : { "state" : "translated", "value" : "로그인 시 실행은 시스템 설정에서 승인이 필요합니다." } }, "it" : { "stringUnit" : { "state" : "translated", "value" : "L’avvio all’accesso richiede approvazione nelle Impostazioni di Sistema." } }, "id" : { "stringUnit" : { "state" : "translated", "value" : "Jalankan saat login memerlukan persetujuan di Pengaturan Sistem." } }, "fr" : { "stringUnit" : { "state" : "translated", "value" : "Le lancement à l’ouverture de session nécessite une approbation dans Réglages Système." } } } },
    "settings.launchAtLogin.notFound" : { "localizations" : { "en" : { "stringUnit" : { "state" : "translated", "value" : "Move MFuse into /Applications before enabling launch at login." } }, "zh-Hans" : { "stringUnit" : { "state" : "translated", "value" : "启用登录时启动前，请先将 MFuse 移到 /Applications。" } }, "zh-Hant" : { "stringUnit" : { "state" : "translated", "value" : "啟用登入時啟動前，請先將 MFuse 移到 /Applications。" } }, "es" : { "stringUnit" : { "state" : "translated", "value" : "Mueve MFuse a /Applications antes de activar el inicio al iniciar sesión." } }, "ja" : { "stringUnit" : { "state" : "translated", "value" : "ログイン時に起動を有効にする前に、MFuse を /Applications に移動してください。" } }, "ko" : { "stringUnit" : { "state" : "translated", "value" : "로그인 시 실행을 켜기 전에 MFuse를 /Applications로 이동하세요." } }, "it" : { "stringUnit" : { "state" : "translated", "value" : "Sposta MFuse in /Applications prima di abilitare l’avvio all’accesso." } }, "id" : { "stringUnit" : { "state" : "translated", "value" : "Pindahkan MFuse ke /Applications sebelum mengaktifkan jalankan saat login." } }, "fr" : { "stringUnit" : { "state" : "translated", "value" : "Déplacez MFuse dans /Applications avant d’activer le lancement à l’ouverture de session." } } } },
